# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# Diese Werte werden von Docker Compose UND MicroProfile Config verwendet
# WICHTIG: Diese Datei hat LF Line-Endings (nicht CRLF)!
# =============================================================================

# PostgreSQL - Single Container Instance (Port 5432)
# Superuser für Container-Management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PostgreSQL Schema: jeeeraaah (Application Database)
# User/Password entspricht dem Schema-Namen
POSTGRES_JEEERAAAH_DB=jeeeraaah
POSTGRES_JEEERAAAH_USER=jeeeraaah
POSTGRES_JEEERAAAH_PASSWORD=jeeeraaah

# PostgreSQL Schema: lib_test (Integration Tests)
# User/Password entspricht dem Schema-Namen
POSTGRES_LIB_TEST_DB=lib_test
POSTGRES_LIB_TEST_USER=lib_test
POSTGRES_LIB_TEST_PASSWORD=lib_test

# PostgreSQL Schema: keycloak (Keycloak Persistence)
# User/Password entspricht dem Schema-Namen
POSTGRES_KEYCLOAK_DB=keycloak
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=keycloak

# Keycloak Admin Console Credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak Test User Credentials (for testing mode)
KEYCLOAK_TEST_USERNAME=test
KEYCLOAK_TEST_PASSWORD=test

# Keycloak Realm Name (wird auch von Java verwendet)
KEYCLOAK_REALM=jeeeraaah-realm

# =============================================================================
# Proxy Configuration (für Docker Build hinter Firewalls)
# =============================================================================
# Uncomment and configure if you are behind a corporate proxy
# Replace <USER>, <PASSWORD>, <PROXY_HOST>, and <PROXY_PORT> with your values
#
# HTTP_PROXY=http://<USER>:<PASSWORD>@<PROXY_HOST>:<PROXY_PORT>
# HTTPS_PROXY=http://<USER>:<PASSWORD>@<PROXY_HOST>:<PROXY_PORT>
# NO_PROXY=localhost,127.0.0.1,*.local,172.16.0.0/12,10.0.0.0/8
#
# Example for GKD-RE network (Linux):
# HTTP_PROXY=http://gkd-re%5Clinuxupdateuser:PASSWORD@172.16.28.3:8080
# HTTPS_PROXY=http://gkd-re%5Clinuxupdateuser:PASSWORD@172.16.28.3:8080
# NO_PROXY=localhost,127.0.0.1,*.local,172.16.0.0/12,10.0.0.0/8

