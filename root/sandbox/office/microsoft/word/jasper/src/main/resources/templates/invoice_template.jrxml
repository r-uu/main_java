<?xml version="1.0" encoding="UTF-8"?>
<!--
	WICHTIG: Dieses Template ist ein einfaches Starter-Template.
	Für optimale Ergebnisse sollten Sie dieses Template in Jaspersoft Studio öffnen
	und visuell anpassen. Siehe JASPERSOFT-STUDIO-SETUP.md für Details.
-->
<jasperReport
	xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="invoice_template"
	pageWidth="595"
	pageHeight="842"
	columnWidth="535"
	leftMargin="30"
	rightMargin="30"
	topMargin="40"
	bottomMargin="40">

	<!-- Parameter -->
	<parameter name="INVOICE_NUMBER" class="java.lang.String"/>
	<parameter name="INVOICE_DATE" class="java.time.LocalDate"/>
	<parameter name="CUSTOMER_NAME" class="java.lang.String"/>
	<parameter name="CUSTOMER_ADDRESS" class="java.lang.String"/>
	<parameter name="TOTAL_AMOUNT" class="java.math.BigDecimal"/>

	<!-- Felder aus InvoiceItem -->
	<field name="description" class="java.lang.String"/>
	<field name="quantity" class="java.lang.Integer"/>
	<field name="unitPrice" class="java.math.BigDecimal"/>
	<field name="netTotal" class="java.math.BigDecimal"/>
	<field name="vatAmount" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>

	<!-- Variablen für Zwischensummen und Überträge -->
	<variable name="PAGE_TOTAL" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
		<initialValueExpression><![CDATA[BigDecimal.ZERO]]></initialValueExpression>
	</variable>

	<variable name="RUNNING_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
		<initialValueExpression><![CDATA[BigDecimal.ZERO]]></initialValueExpression>
	</variable>

	<variable name="PREVIOUS_PAGE_TOTAL" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$V{RUNNING_TOTAL}.subtract($V{PAGE_TOTAL})]]></variableExpression>
	</variable>

	<!-- TITEL (einmal am Anfang) -->
	<title>
		<band height="150" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="200" height="30"/>
				<textElement>
					<font size="20" isBold="true"/>
				</textElement>
				<text><![CDATA[RECHNUNG]]></text>
			</staticText>

			<staticText>
				<reportElement x="0" y="40" width="100" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Rechnungsnr.:]]></text>
			</staticText>
			<textField>
				<reportElement x="100" y="40" width="200" height="20"/>
				<textFieldExpression><![CDATA[$P{INVOICE_NUMBER}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="60" width="100" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Datum:]]></text>
			</staticText>
			<textField>
				<reportElement x="100" y="60" width="200" height="20"/>
				<textFieldExpression><![CDATA[$P{INVOICE_DATE}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="90" width="100" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Kunde:]]></text>
			</staticText>
			<textField>
				<reportElement x="100" y="90" width="300" height="40"/>
				<textFieldExpression><![CDATA[$P{CUSTOMER_NAME} + "\n" + $P{CUSTOMER_ADDRESS}]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<!-- PAGE HEADER (auf jeder Seite außer der ersten) -->
	<pageHeader>
		<band height="60">
			<printWhenExpression><![CDATA[$V{PAGE_NUMBER} > 1]]></printWhenExpression>

			<staticText>
				<reportElement x="0" y="0" width="150" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Fortsetzung Rechnung:]]></text>
			</staticText>
			<textField>
				<reportElement x="150" y="0" width="200" height="20"/>
				<textFieldExpression><![CDATA[$P{INVOICE_NUMBER}]]></textFieldExpression>
			</textField>

			<!-- Übertrag von vorheriger Seite -->
			<staticText>
				<reportElement x="300" y="30" width="150" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Übertrag von Seite ]]></text>
			</staticText>
			<textField>
				<reportElement x="450" y="30" width="30" height="20"/>
				<textElement textAlignment="Left"><font isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$V{PAGE_NUMBER} - 1]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="480" y="30" width="55" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$V{PREVIOUS_PAGE_TOTAL}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>

	<!-- SPALTEN-HEADER -->
	<columnHeader>
		<band height="30" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="0" width="200" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Beschreibung]]></text>
			</staticText>
			<staticText>
				<reportElement x="200" y="0" width="50" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Menge]]></text>
			</staticText>
			<staticText>
				<reportElement x="250" y="0" width="80" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Einzelpreis]]></text>
			</staticText>
			<staticText>
				<reportElement x="330" y="0" width="80" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Netto]]></text>
			</staticText>
			<staticText>
				<reportElement x="410" y="0" width="60" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[MwSt]]></text>
			</staticText>
			<staticText>
				<reportElement x="470" y="0" width="65" height="20"/>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Gesamt]]></text>
			</staticText>
			<line>
				<reportElement x="0" y="25" width="535" height="1"/>
			</line>
		</band>
	</columnHeader>

	<!-- DETAIL (Rechnungspositionen) -->
	<detail>
		<band height="25" splitType="Stretch">
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="0" width="200" height="20"/>
				<textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="200" y="0" width="50" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="250" y="0" width="80" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{unitPrice}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="330" y="0" width="80" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{netTotal}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="410" y="0" width="60" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{vatAmount}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="470" y="0" width="65" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<!-- PAGE FOOTER (Zwischensumme pro Seite) -->
	<pageFooter>
		<band height="60">
			<!-- Zwischensumme nur anzeigen, wenn nicht letzte Seite -->
			<textField evaluationTime="Auto">
				<reportElement x="0" y="10" width="535" height="1"/>
				<printWhenExpression><![CDATA[$V{PAGE_NUMBER} < $V{PAGE_COUNT}]]></printWhenExpression>
			</textField>

			<staticText>
				<reportElement x="350" y="10" width="120" height="20"/>
				<printWhenExpression><![CDATA[$V{PAGE_NUMBER} < $V{PAGE_COUNT}]]></printWhenExpression>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<text><![CDATA[Zwischensumme Seite ]]></text>
			</staticText>
			<textField>
				<reportElement x="470" y="10" width="10" height="20"/>
				<printWhenExpression><![CDATA[$V{PAGE_NUMBER} < $V{PAGE_COUNT}]]></printWhenExpression>
				<textElement><font isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00 €">
				<reportElement x="480" y="10" width="55" height="20"/>
				<printWhenExpression><![CDATA[$V{PAGE_NUMBER} < $V{PAGE_COUNT}]]></printWhenExpression>
				<textElement textAlignment="Right"><font isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$V{PAGE_TOTAL}]]></textFieldExpression>
			</textField>

			<!-- Seitenzahl -->
			<textField>
				<reportElement x="0" y="40" width="535" height="20"/>
				<textElement textAlignment="Center"/>
				<textFieldExpression><![CDATA["Seite " + $V{PAGE_NUMBER} + " von " + $V{PAGE_COUNT}]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>

	<!-- SUMMARY (Endsumme) -->
	<summary>
		<band height="80">
			<line>
				<reportElement x="0" y="5" width="535" height="1"/>
			</line>
			<line>
				<reportElement x="0" y="8" width="535" height="1"/>
			</line>

			<staticText>
				<reportElement x="350" y="20" width="120" height="25"/>
				<textElement textAlignment="Right">
					<font size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[GESAMTSUMME:]]></text>
			</staticText>
			<textField pattern="#,##0.00 €">
				<reportElement x="470" y="20" width="65" height="25"/>
				<textElement textAlignment="Right">
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{TOTAL_AMOUNT}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="55" width="535" height="20"/>
				<textElement textAlignment="Center">
					<font size="8" isItalic="true"/>
				</textElement>
				<text><![CDATA[Vielen Dank für Ihren Auftrag!]]></text>
			</staticText>
		</band>
	</summary>
</jasperReport>

