# ============================================================================
# Open Liberty Server Environment Configuration (EXAMPLE/TEMPLATE)
# ============================================================================
# This file is a TEMPLATE. Copy it to 'server.env' and customize for your environment.
#
# IMPORTANT: server.env should be git-ignored (machine-specific)
#
# This file is loaded by Open Liberty and provides environment variables
# for server.xml configuration.
# ============================================================================

# Environment-specific settings
environment=development
# Set to 'development' or 'production'

# ============================================================================
# HTTP/HTTPS Ports
# ============================================================================
default_http_port=9080
default_https_port=9443
default_host_name=*

# ============================================================================
# PostgreSQL DataSource Configuration
# ============================================================================
# These values are used in server.xml for database connection
# IMPORTANT: Must match the credentials from docker-compose.yml/.env
# Docker: User/Password entspricht dem Schema-Namen (jeeeraaah:jeeeraaah)
datasource_server_host=localhost
datasource_server_port=5432
datasource_database=jeeeraaah
datasource_database_username=jeeeraaah
datasource_database_password=jeeeraaah

# ============================================================================
# Default Keystore Password
# ============================================================================
# Used for SSL/TLS configuration
default_keystore_password=changeit

# ============================================================================
# Keycloak Configuration (optional, if needed by server.xml)
# ============================================================================
keycloak_host=localhost
keycloak_port=8080
keycloak_realm=realm_default
keycloak_client_id=jeeeraaah-backend
