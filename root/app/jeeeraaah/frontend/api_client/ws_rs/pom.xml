	<parent>
		<groupId>r-uu</groupId>
		<artifactId>r-uu.app.jeeeraaah.frontend.api_client</artifactId>
		<version>0.0.1</version>
	</parent>

	<dependencies>

		<!-- jackson -->
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
