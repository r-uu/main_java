		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.jakarta.rs</groupId>
			<artifactId>jackson-jakarta-rs-json-provider</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.datatype</groupId>
			<artifactId>jackson-datatype-jdk8</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.datatype</groupId>
			<artifactId>jackson-datatype-jsr310</artifactId>
		</dependency>

		<!-- jakarta apis -->
		<dependency>
			<groupId>jakarta.activation</groupId>
			<artifactId>jakarta.activation-api</artifactId>
		</dependency>
		<dependency>
			<groupId>jakarta.annotation</groupId>
			<artifactId>jakarta.annotation-api</artifactId>
		</dependency>
		<dependency>
			<groupId>jakarta.enterprise</groupId>
			<artifactId>jakarta.enterprise.cdi-api</artifactId>
		</dependency>
		<dependency>
			<groupId>jakarta.json</groupId>
			<artifactId>jakarta.json-api</artifactId>
		</dependency>
		<dependency>
			<groupId>jakarta.ws.rs</groupId>
			<artifactId>jakarta.ws.rs-api</artifactId>
		</dependency>

		<!-- jakarta implementations -->
		<dependency>
			<groupId>com.sun.activation</groupId>
			<artifactId>jakarta.activation</artifactId>
		</dependency>

		<!-- micro profile config -->
		<dependency>
			<groupId>org.eclipse.microprofile.config</groupId>
			<artifactId>microprofile-config-api</artifactId>
		</dependency>

		<!-- Project Libraries -->
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.cdi.common</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.cdi.se</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.jackson</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.mapstruct</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.mapstruct.spi</artifactId>
			<scope>provided</scope>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.mp_config</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.util</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.ws_rs</artifactId>
        </dependency>

		<!-- common api dependencies -->
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.app.jeeeraaah.common.api.bean</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.app.jeeeraaah.common.api.domain</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.app.jeeeraaah.common.api.mapping</artifactId>
        </dependency>
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.app.jeeeraaah.common.api.ws_rs</artifactId>
        </dependency>

		<!-- Lombok -->
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
			<scope>provided</scope>
			<optional>true</optional>
		</dependency>

		<!-- Test Dependencies -->
		<dependency>
			<groupId>r-uu</groupId>
			<artifactId>r-uu.lib.junit</artifactId>
			<scope>test</scope>
        </dependency>
		<dependency>
			<groupId>org.assertj</groupId>
			<artifactId>assertj-core</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>jakarta.transaction</groupId>
			<artifactId>jakarta.transaction-api</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- Jersey Client + Dependencies - Runtime für DBCommandRunner -->
		<dependency>
			<groupId>org.glassfish.jersey.core</groupId>
			<artifactId>jersey-client</artifactId>
		</dependency>
		<dependency>
			<groupId>org.glassfish.jersey.core</groupId>
			<artifactId>jersey-common</artifactId>
		</dependency>
		<dependency>
			<groupId>org.glassfish.jersey.inject</groupId>
			<artifactId>jersey-hk2</artifactId>
		</dependency>

		<!-- Weld SE für CDI - Runtime für DBCommandRunner, Test für Tests -->
		<dependency>
			<groupId>org.jboss.weld.se</groupId>
			<artifactId>weld-se-core</artifactId>
			<!--			<version>6.2.0.Final</version>-->
			<!-- Explicit compile scope to override parent's test scope for standalone runners -->
			<scope>compile</scope>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<!-- Compiler Plugin - exclude test module-info.java from Maven compilation -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<executions>
					<execution>
						<id>default-testCompile</id>
						<phase>test-compile</phase>
						<goals>
							<goal>testCompile</goal>
						</goals>
						<configuration>
							<testExcludes>
								<testExclude>**/module-info.java</testExclude>
							</testExcludes>
						</configuration>
					</execution>
				</executions>
			</plugin>

			<!-- Surefire für Unit-Tests -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<forkCount>1</forkCount>
					<reuseForks>false</reuseForks>
					<argLine>
						--add-opens java.base/java.lang=ALL-UNNAMED
						--add-opens java.base/java.util=ALL-UNNAMED
					</argLine>
				</configuration>
			</plugin>

			<!-- Failsafe Plugin: Integration Tests (require running Liberty server)
			     
			     Configuration (updated Dec 2025 for flexible CI/CD):
			     - Tests follow Maven *IT.java naming convention
			     - Tests use @DisabledOnServerNotListening annotation to detect server availability
			     - skipITs property allows explicit test skipping via -DskipITs=true
			     - testFailureIgnore=true: build succeeds even if tests fail
			       (useful when server is down or backend has issues)
			     
			     Normal workflow:
			     - Server running: Tests execute (may fail but build continues)
			     - Server down: Tests auto-skip via annotation, BUILD SUCCESS
			     - No -DskipITs parameter needed for normal builds
			     
			     See: TestDBCommands.java, TestTaskGroupServiceCreate.java (renamed to *IT.java) -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-failsafe-plugin</artifactId>
				<configuration>
					<!-- Respect skipITs property for explicit test skipping -->
					<skipITs>${skipITs}</skipITs>

					<!-- Allow build to succeed even if integration tests fail
					     (e.g., server down, backend issues, network problems) -->
					<testFailureIgnore>true</testFailureIgnore>

					<!-- Fork configuration: one JVM per test class, no reuse -->
					<forkCount>1</forkCount>
					<reuseForks>false</reuseForks>
					<argLine>
						--add-opens java.base/java.lang=ALL-UNNAMED
						--add-opens java.base/java.util=ALL-UNNAMED
					</argLine>
					<systemPropertyVariables>
						<jeeeraaah.rest-api.host>localhost</jeeeraaah.rest-api.host>
						<jeeeraaah.rest-api.port>9080</jeeeraaah.rest-api.port>
					</systemPropertyVariables>
					<includes>
						<include>**/*IT.java</include>
					</includes>
				</configuration>
				<executions>
					<execution>
						<goals>
							<goal>integration-test</goal>
							<goal>verify</goal>
						</goals>
					</execution>
				</executions>
			</plugin>

			<!-- Exec Plugin für DBCommandRunner JPMS-Launch -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<configuration>
					<!-- Default configuration for exec:java (better for debugging) -->
					<mainClass>de.ruu.app.jeeeraaah.frontend.api.client.ws.rs.dbcommand.DBCommandRunner</mainClass>
					<includeProjectDependencies>true</includeProjectDependencies>
					<includePluginDependencies>false</includePluginDependencies>
					<classpathScope>runtime</classpathScope>
					<!-- Prevent ClassNotFoundException on Weld shutdown by using system classloader -->
					<cleanupDaemonThreads>false</cleanupDaemonThreads>
					<systemProperties>
						<systemProperty>
							<key>jeeeraaah.rest-api.host</key>
							<value>localhost</value>
						</systemProperty>
						<systemProperty>
							<key>jeeeraaah.rest-api.port</key>
							<value>9080</value>
						</systemProperty>
					</systemProperties>
					<commandlineArgs>--add-opens java.base/java.lang=ALL-UNNAMED --add-opens
						java.base/java.util=ALL-UNNAMED</commandlineArgs>
				</configuration>
				<executions>
					<!-- exec:exec - Alternative for production-like execution -->
					<execution>
						<id>exec-execution</id>
						<goals>
							<goal>exec</goal>
						</goals>
						<configuration>
							<executable>java</executable>
							<arguments>
								<argument>--add-opens</argument>
								<argument>java.base/java.lang=ALL-UNNAMED</argument>
								<argument>--add-opens</argument>
								<argument>java.base/java.util=ALL-UNNAMED</argument>
								<argument>-classpath</argument>
								<classpath />
								<argument>de.ruu.app.jeeeraaah.frontend.api.client.ws.rs.dbcommand.DBCommandRunner</argument>
							</arguments>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

</project>
